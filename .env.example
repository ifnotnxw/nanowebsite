# Порт сервера (по умолчанию 3000)
PORT=3000

# Окружение: development / production
NODE_ENV=production

# Учетные данные администратора
# Логин:
ADMIN_LOGIN=admin

# Вариант 1 (рекомендуется): bcrypt-хэш пароля
# Например, результат bcrypt.hashSync("сильный-пароль", 10)
# ADMIN_PASSWORD_BCRYPT=$2a$10$examplehashhere

# Вариант 2: sha256-хэш пароля (устаревший, для совместимости)
# ADMIN_PASSWORD_HASH=

# Вариант 3: открытый пароль (только для локальной разработки)
# ADMIN_PASSWORD=

# JWT-секреты для админских сессий (ЗАДАЙТЕ СВОИ ЗНАЧЕНИЯ В ПРОДАКШЕНЕ)
# JWT_ACCESS_SECRET=super-secret-access-key-change-me
# JWT_REFRESH_SECRET=super-secret-refresh-key-change-me

# CORS: список разрешённых origin для продакшена (через запятую).
# Если оставить пустым, будут разрешены все origin (поведение по умолчанию).
CORS_ORIGINS=https://example.com,https://sub.example.com

# Опционально: логины менеджеров, которые получают роль manager (через запятую)
# MANAGER_LOGINS=manager1,manager2

# AI перевод карточек товаров (backend-only)
# Поддерживаемый провайдер: openai (или disabled/off для отключения)
AI_TRANSLATION_PROVIDER=openai
AI_TRANSLATION_API_KEY=
AI_TRANSLATION_MODEL=gpt-4.1-mini
# Для совместимых прокси можно переопределить базовый URL
# AI_TRANSLATION_BASE_URL=https://api.openai.com/v1
# AI_TRANSLATION_TIMEOUT_MS=45000
# AI_TRANSLATION_RETRIES=2

# Общие языки мультиязычной платформы (kz в UI = kk внутри API/БД)
SOURCE_LANGUAGE=ru
TARGET_LANGUAGES=en,kz

# Совместимость со старой конфигурацией (если SOURCE/TARGET не заданы)
PRODUCT_SOURCE_LANGUAGE=ru
PRODUCT_TARGET_LANGUAGES=en,kz

# UI словарь: опционально авто-генерировать отсутствующие переводы через AI
# Рекомендуется включать только в controlled flow (staging/admin trigger)
# UI_TRANSLATION_AUTO_GENERATE=0
# UI_TRANSLATION_BATCH_SIZE=80

